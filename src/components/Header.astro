---
const navLinks = [
  { href: '#home',    label: 'Home' },
  { href: '#travels', label: 'Travels' },
];
---

<header id="site-header" style="position:fixed;top:0;left:0;right:0;z-index:50;padding:1.25rem 1.5rem;transition:background 0.3s,padding 0.3s;">
  <div style="max-width:72rem;margin:0 auto;display:flex;align-items:center;justify-content:space-between;">

    <div></div>

    <!-- Desktop nav -->
    <nav style="display:none;" id="desktop-nav">
      {navLinks.map((link) => (
        <a
          href={link.href}
          style="font-size:0.8125rem;font-weight:500;color:var(--soft);text-decoration:none;letter-spacing:0.04em;transition:color 0.2s;margin-left:2rem;"
          onmouseover="this.style.color='var(--accent)'"
          onmouseout="this.style.color='var(--soft)'"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button id="menu-btn" aria-label="Menu" style="background:none;border:none;cursor:pointer;color:var(--soft);display:block;">
      <svg id="icon-open" width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none;">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="display:none;margin-top:0.75rem;border:1px solid var(--border);border-radius:0.75rem;background:rgba(20,20,20,0.97);backdrop-filter:blur(12px);overflow:hidden;">
    {navLinks.map((link) => (
      <a
        href={link.href}
        data-mobile-link
        style="display:block;padding:1rem 1.5rem;font-size:0.875rem;font-weight:500;color:var(--soft);text-decoration:none;border-bottom:1px solid var(--border);transition:color 0.2s,background 0.2s;"
        onmouseover="this.style.color='var(--accent)';this.style.background='rgba(240,192,64,0.04)'"
        onmouseout="this.style.color='var(--soft)';this.style.background='transparent'"
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<script is:inline>
  (() => {
    const header  = document.getElementById('site-header');
    const desktopNav = document.getElementById('desktop-nav');
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen  = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    // Show desktop nav on md+ (>=768px)
    function applyLayout() {
      desktopNav.style.display = window.innerWidth >= 768 ? 'flex' : 'none';
      if (window.innerWidth >= 768) {
        menuBtn.style.display = 'none';
        mobileMenu.style.display = 'none';
      } else {
        menuBtn.style.display = 'block';
      }
    }
    applyLayout();
    window.addEventListener('resize', applyLayout);

    // Scroll glass effect
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.style.background = 'rgba(12,12,12,0.88)';
        header.style.backdropFilter = 'blur(16px)';
        header.style.borderBottom = '1px solid var(--border)';
        header.style.padding = '0.875rem 1.5rem';
      } else {
        header.style.background = 'transparent';
        header.style.backdropFilter = 'none';
        header.style.borderBottom = 'none';
        header.style.padding = '1.25rem 1.5rem';
      }
    }, { passive: true });

    // Mobile toggle
    menuBtn.addEventListener('click', () => {
      const open = mobileMenu.style.display === 'none';
      mobileMenu.style.display = open ? 'block' : 'none';
      iconOpen.style.display  = open ? 'none'  : 'block';
      iconClose.style.display = open ? 'block' : 'none';
    });

    document.querySelectorAll('[data-mobile-link]').forEach((l) => {
      l.addEventListener('click', () => {
        mobileMenu.style.display = 'none';
        iconOpen.style.display = 'block';
        iconClose.style.display = 'none';
      });
    });

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(a.getAttribute('href').slice(1));
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  })();
</script>
