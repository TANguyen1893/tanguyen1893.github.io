---
const facts = [
  { label: 'Role',       value: 'Senior Software Developer at AppDirect' },
  { label: 'Location',   value: 'Montréal, QC' },
  { label: 'Stack',      value: 'Java · TypeScript · Node.js' },
  { label: 'Supporting', value: 'Arsenal FC · Toronto Raptors' },
  { label: 'Interests',  value: 'Biking · Gardening · Tutoring' },
  { label: 'Tinkering',  value: 'Home automation' },
];

const CDN = 'https://res.cloudinary.com/dl4svce1s/image/upload';
const heroBg = `${CDN}/w_1600,c_fill,g_auto,f_auto,q_auto/site/fulls/orford_trail.jpg`;
const portrait = 'https://res.cloudinary.com/dl4svce1s/image/upload/f_auto,q_auto/site/fulls/me.jpg';
---

<style>
  #hero-photo-mobile { display: block; }
  #hero-photo        { display: none;  }

  @media (min-width: 768px) {
    #hero-photo-mobile { display: none;  }
    #hero-photo        { display: block; }
  }
</style>

<section id="home" style="padding:8rem 1.5rem 6rem;position:relative;overflow:hidden;min-height:100svh;display:flex;align-items:center;">

  <!-- ── Background ──────────────────────────────────────────── -->
  <img
    src={heroBg}
    alt=""
    aria-hidden="true"
    fetchpriority="high"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:62% center;opacity:0.35;pointer-events:none;z-index:0;"
  />

  <!-- Left fade — protects text legibility on desktop -->
  <div style="position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(to right,var(--bg) 0%,color-mix(in srgb,var(--bg) 80%,transparent) 45%,color-mix(in srgb,var(--bg) 30%,transparent) 70%,transparent 100%);"></div>
  <!-- Bottom fade — blends hero into the rest of the page -->
  <div style="position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(to top,var(--bg) 0%,transparent 45%);"></div>
  <!-- Top-edge vignette — stops the image feeling cut off at the header -->
  <div style="position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(to bottom,color-mix(in srgb,var(--bg) 60%,transparent) 0%,transparent 18%);"></div>
  <!-- Right fade — prevents image clashing with the portrait card on desktop -->
  <div style="position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(to left,color-mix(in srgb,var(--bg) 80%,transparent) 0%,transparent 42%);"></div>

  <!-- ── Content ────────────────────────────────────────────── -->
  <div style="position:relative;z-index:2;max-width:72rem;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr;gap:4rem;align-items:start;" id="hero-grid">

    <!-- Left: all content -->
    <div style="display:flex;flex-direction:column;gap:2.5rem;">

      <div data-animate>
        <h1 style="font-size:clamp(3.5rem,9vw,8rem);font-weight:900;line-height:0.93;letter-spacing:-0.03em;color:var(--text);">
          Tuan&#8209;Anh<br />
          <span style="color:var(--accent);">Nguyen</span>
        </h1>
      </div>

      <div data-animate data-delay="1" style="max-width:36rem;">
        <p style="font-size:1.125rem;color:var(--soft);line-height:1.7;font-weight:400;">
          Software developer at&nbsp;AppDirect, based in&nbsp;Montréal.
          Curious traveller, lifelong Arsenal&nbsp;FC fan, and weekend cyclist.
        </p>
      </div>

      <!-- Mobile portrait — shown between subtitle and bio on small screens -->
      <div id="hero-photo-mobile" data-animate data-delay="2"
        style="position:relative;width:100%;height:clamp(280px,75vw,360px);border-radius:1.25rem;overflow:hidden;">
        <img
          src={portrait}
          alt="Tuan-Anh Nguyen"
          style="width:100%;height:100%;object-fit:cover;object-position:center 15%;"
        />
        <!-- bottom fade blends into page bg -->
        <div style="position:absolute;inset:0;background:linear-gradient(to top,var(--bg) 0%,transparent 50%);"></div>
        <!-- subtle side fades so it doesn't look hard-cropped -->
        <div style="position:absolute;inset:0;background:linear-gradient(to right,color-mix(in srgb,var(--bg) 40%,transparent) 0%,transparent 20%);"></div>
        <div style="position:absolute;inset:0;background:linear-gradient(to left,color-mix(in srgb,var(--bg) 40%,transparent) 0%,transparent 20%);"></div>
      </div>

      <!-- Narrative -->
      <div data-animate data-delay="3" style="display:flex;flex-direction:column;gap:1.25rem;color:var(--soft);font-size:1rem;line-height:1.75;max-width:36rem;">
        <p>
          I'm a software developer at AppDirect in Montréal, working with
          Java, TypeScript, and Node.js. Outside of work I like to tinker —
          lately that means home automation projects, wiring up smart home devices and
          building little automations that make daily life slightly more interesting.
        </p>
        <p>
          I've been an Arsenal supporter since around 2000, right when Thierry Henry
          arrived and changed everything. I finally made it to the Emirates in September
          2019 to see them beat Aston Villa 3–2 with a last-minute Aubameyang free-kick.
          I took a red-eye flight to London just to be there.
        </p>
        <p>
          I grew up playing basketball, which is how I became a lifelong Raptors fan.
          These days my free time goes to cycling around Montréal, gardening, cooking,
          and occasionally tutoring.
        </p>
      </div>

      <!-- Quick facts -->
      <dl data-animate data-delay="4" style="display:flex;flex-direction:column;gap:0;max-width:36rem;">
        {facts.map((f, i) => (
          <div style={`display:flex;align-items:baseline;gap:1rem;padding:0.65rem 0;border-bottom:1px solid var(--border);${i === 0 ? 'border-top:1px solid var(--border);' : ''}`}>
            <dt style="flex-shrink:0;width:6rem;font-size:0.65rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);">{f.label}</dt>
            <dd style="font-size:0.9rem;color:var(--soft);">{f.value}</dd>
          </div>
        ))}
      </dl>

    </div>

    <!-- Right: sticky photo (desktop only) -->
    <div data-animate="right" id="hero-photo" style="position:sticky;top:6rem;border-radius:1.25rem;overflow:hidden;height:clamp(400px,60vh,580px);">
      <img
        src={portrait}
        alt="Tuan-Anh Nguyen"
        style="width:100%;height:100%;object-fit:cover;object-position:center top;"
      />
      <div style="position:absolute;inset:0;background:linear-gradient(to top,var(--bg) 0%,transparent 40%);"></div>
      <div style="position:absolute;inset:0;background:linear-gradient(to right,var(--bg) 0%,transparent 20%);"></div>
    </div>

  </div>

</section>

<script is:inline>
  function heroLayout() {
    const grid = document.getElementById('hero-grid');
    if (window.innerWidth >= 768) {
      grid.style.gridTemplateColumns = '1.2fr 1fr';
    } else {
      grid.style.gridTemplateColumns = '1fr';
    }
  }
  heroLayout();
  window.addEventListener('resize', heroLayout);
</script>
